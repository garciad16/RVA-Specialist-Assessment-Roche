y = "System Organ Class",
fill = "Severity"
) +
scale_fill_manual(values = c(
"MILD"     = "#FCBBA1",
"MODERATE" = "#FB6A4A",
"SEVERE"   = "#CB181D"
)) +
theme_minimal() +
theme(
axis.text.y = element_text(size = 7),
plot.title = element_text(hjust = 0.5)
)
# Question 2: AE Severity Visualization
# Horizontal stacked bar chart of adverse events by body system and severity
# Uses {ggplot2} with pharmaverseadam ADAE dataset
# --- Install & Load Packages -------------------------------------------------
required_packages <- c("pharmaverseadam", "tidyverse", "ggplot2")
for (pkg in required_packages) {
if (!requireNamespace(pkg, quietly = TRUE)) {
install.packages(pkg, repos = "https://cloud.r-project.org")
}
}
library(pharmaverseadam)
library(tidyverse)
library(ggplot2)
# --- Load Data ---------------------------------------------------------------
# Q2 only uses ADAE — no need for ADSL here.
adae <- pharmaverseadam::adae
# --- Data Exploration --------------------------------------------------------
# 1. OVERVIEW — What's in the dataset?
cat("=== ADAE ===\n")
cat("Rows:", nrow(adae), "| Columns:", ncol(adae), "\n")
glimpse(adae)
# From glimpse, the columns we need for this question:
#   USUBJID  — Unique patient ID (for counting unique subjects)
#   AESOC    — Body system category (e.g., "CARDIAC DISORDERS") — our Y-axis
#   AESEV    — Severity level (e.g., "MILD", "MODERATE", "SEVERE") — our color fill
# 2. DISTRIBUTIONS — Check the fields we'll use
# What severity levels exist?
cat("\n=== AESEV values ===\n")
print(count(adae, AESEV))
# How many body systems (AESOC)?
cat("\n=== Number of unique AESOC values ===\n")
cat(n_distinct(adae$AESOC), "body systems\n")
# 3. TRANSFORM — Prepare data for the chart
# --- Step 1: De-duplicate -----------------------------------------------------
# The question says: "Ensure each subject is counted at most once per severity
# level within each SOC."
# So if a patient had 3 MILD headache events under NERVOUS SYSTEM DISORDERS,
# they count as 1 toward the MILD bar for that body system.
ae_dedup <- adae %>%
distinct(USUBJID, AESOC, AESEV)
cat("\n=== Step 1: De-duplication ===\n")
cat("Rows before:", nrow(adae), "\n")
cat("Rows after:", nrow(ae_dedup), "\n")
# --- Step 2: Count unique subjects per AESOC per AESEV -----------------------
# Each row in ae_dedup is already one unique patient + body system + severity,
# so we just count the rows per group.
ae_counts <- ae_dedup %>%
count(AESOC, AESEV, name = "n_subjects")
cat("=== Step 2: Counts per body system per severity ===\n")
print(head(ae_counts, 10))
# Now we have the raw counts. Before building the chart, we need to:
# Step 3: Order AESOC so the chart Y-axis goes from fewest to most subjects
# Step 4: Order AESEV so the bar segments always stack MILD → MODERATE → SEVERE
# --- Step 3: Order AESOC by total subjects -----------------------------------
# The question says: "ordered by increasing frequency of total subjects per SOC"
# Right now ae_counts has multiple rows per body system (one per severity).
# The question says: "Bars must be ordered by increasing frequency of total subjects per SOC."
# By default, ggplot would order the Y-axis alphabetically, which doesn't match that requirement.
# So we need to sum up n_subjects per body system, then tell ggplot to use that order instead.
# fct_reorder() does this in one step — it reorders AESOC by the sum of n_subjects.
ae_counts$AESOC <- fct_reorder(ae_counts$AESOC, ae_counts$n_subjects, .fun = sum)
# Verify: print the factor levels to confirm the order
# First level = bottom of chart (fewest), last level = top of chart (most)
cat("\n=== Step 3: AESOC factor levels (bottom to top of chart) ===\n")
print(levels(ae_counts$AESOC))
# --- Step 4: Set severity order for consistent stacking ----------------------
# Make AESEV an ordered factor so the bars always stack MILD → MODERATE → SEVERE
ae_counts$AESEV <- factor(ae_counts$AESEV, levels = c("MILD", "MODERATE", "SEVERE"))
# --- Step 5: Build the chart -------------------------------------------------
ae_plot <- ggplot(ae_counts, aes(x = n_subjects, y = AESOC, fill = AESEV)) +
geom_bar(stat = "identity") +
labs(
title = "Unique Subjects per SOC and Severity Level",
x = "Number of Unique Subjects",
y = "System Organ Class",
fill = "Severity"
) +
scale_fill_manual(values = c(
"MILD"     = "#FCBBA1",
"MODERATE" = "#FB6A4A",
"SEVERE"   = "#CB181D"
)) +
theme_minimal() +
theme(
axis.text.y = element_text(size = 7),
plot.title = element_text(hjust = 0.5)
)
# --- Step 6: Save as PNG -----------------------------------------------------
ggsave("ae_severity_chart.png", ae_plot, width = 12, height = 8, dpi = 300)
cat("Chart saved to ae_severity_chart.png\n")
cat("Chart saved to ae_severity_chart.png\n")
