# Question 1: TEAE Summary Table
# Regulatory-compliant summary of Treatment-Emergent Adverse Events
# Uses {gtsummary} with pharmaverseadam ADSL/ADAE datasets
# --- Install & Load Packages -------------------------------------------------
# Installs only if not already present — safe to re-run
required_packages <- c("pharmaverseadam", "tidyverse", "gtsummary", "gt")
for (pkg in required_packages) {
if (!requireNamespace(pkg, quietly = TRUE)) {
install.packages(pkg, repos = "https://cloud.r-project.org")
}
}
library(pharmaverseadam)
library(tidyverse)
library(gtsummary)
# --- Load Data ---------------------------------------------------------------
# pharmaverseadam ships both datasets in-package — no files to download.
adsl <- pharmaverseadam::adsl
adae <- pharmaverseadam::adae
# --- Data Exploration --------------------------------------------------------
# Discovering both datasets from scratch before any transformation.
# 1. OVERVIEW — What's in each dataset?
cat("=== ADSL ===\n")
cat("Rows:", nrow(adsl), "| Columns:", ncol(adsl), "\n")
glimpse(adsl)
cat("\n=== ADAE ===\n")
cat("Rows:", nrow(adae), "| Columns:", ncol(adae), "\n")
glimpse(adae)
# From glimpse output, we can now identify the columns the question asks for:
#   ACTARM   — Treatment arm (e.g., "Placebo", "Xanomeline High Dose")
#   AESOC    — Body system category (e.g., "CARDIAC DISORDERS", "NERVOUS SYSTEM DISORDERS")
#   AEDECOD  — Specific event name (e.g., "ATRIAL FIBRILLATION", "HEADACHE")
#   TRTEMFL  — Flag marking whether an event is treatment-emergent ("Y" or not)
#   USUBJID  — Unique patient ID (exists in both ADSL and ADAE, links them together)
# How do AESOC and AEDECOD relate to each other?
# Let's look at a few AESOC values and what AEDECOD values fall under them.
cat("\n=== AESOC → AEDECOD relationship ===\n")
adae %>%
distinct(USUBJID, AESOC, AEDECOD) %>%
head(20) %>%
print()
# Each AEDECOD belongs to one AESOC — so AESOC is the parent grouping
# and AEDECOD is the specific event within it.
# 2. DISTRIBUTIONS — Check the two fields we filter/group by before transforming
# ACTARM: We split the table columns by treatment arm.
# Need to see what arms exist and how many patients are in each.
cat("\n=== ACTARM in ADSL ===\n")
print(count(adsl, ACTARM))
# TRTEMFL: We filter ADAE to TRTEMFL == "Y" in Step 1. Need to see how the
# data splits so we know how many records that filter keeps vs drops.
cat("\n=== TRTEMFL in ADAE ===\n")
print(count(adae, TRTEMFL))
# 3. TRANSFORM — Apply the requirements from the question
# --- Step 1: Apply TEAE Filter -----------------------------------------------
# The question says: "Treatment-emergent AE records will have TRTEMFL == 'Y'"
# So we filter ADAE to keep only those rows.
adae_teae <- adae %>%
filter(TRTEMFL == "Y")
# Removed NA
cat("=== Step 1: TEAE Filter Applied ===\n")
cat("Records after filter:", nrow(adae_teae), "\n")
# --- Step 2: De-duplicate -----------------------------------------------------
# A patient can have multiple rows for the same event (e.g., 3 headache episodes).
# The table wants "how many patients had headaches" — not "how many headaches happened."
# distinct() keeps one row per patient per event, removing the repeats.
# We keep USUBJID (patient), ACTARM (treatment arm), AESOC (body system),
# and AEDECOD (specific event) — if all four match, it's a duplicate row.
adae_teae_distinct <- adae_teae %>%
distinct(USUBJID, ACTARM, AESOC, AEDECOD)
cat("=== Step 2: De-duplication Applied ===\n")
cat("Duplicate rows removed:", nrow(adae_teae) - nrow(adae_teae_distinct), "\n\n")
cat("Rows after distinct:", nrow(adae_teae_distinct), "\n")
# --- Step 3: Build the TEAE Summary Table ------------------------------------
# tbl_hierarchical() builds a nested table. Here's what each argument does:
#
# variables = c(AESOC, AEDECOD)
#   → From our exploration, we saw each AEDECOD belongs to one AESOC
#   → So AESOC is the parent row, AEDECOD is indented underneath
#   → Order matters: first = parent, second = child
#
# by = ACTARM
#   → Creates one column per treatment arm
#
# denominator = adsl
#   → Percentages are calculated as: patients with event / total patients in arm
#   → The total patients per arm come from ADSL (e.g., Placebo = 86)
#
# id = USUBJID
#   → Tells the function to count unique patients, not rows
#
# overall_row = TRUE
#   → Adds a row at the very top counting patients who had ANY event
teae_table <- adae_teae_distinct %>%
tbl_hierarchical(
variables = c(AESOC, AEDECOD),
by = ACTARM,
denominator = adsl,
id = USUBJID,
overall_row = TRUE
) %>%
# Bold the body system rows (AESOC) so they stand out from the specific events
bold_labels() %>%
# Rename the left column header
modify_header(label ~ "**System Organ Class / Preferred Term**") %>%
# Add a grouped header above the treatment arm columns
modify_spanning_header(
all_stat_cols() ~ "**Treatment Arm**"
)
# --- Step 4: Export to HTML ---------------------------------------------------
teae_table %>%
as_gt() %>%
gt::gtsave("question_1/teae_summary.html")
